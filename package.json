{
  "name": "node-fizz-buzz",
  "version": "1.0.0",
  "type": "module",
  "husky": {
    "pre-commit": "lint-staged"
  },
  "lint-staged": {
    "**/*.ts": "tsc-files --noEmit"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch server.ts",
    "start": "tsx server.ts",
    "type-check": "tsc --noEmit",
    "prepare": "husky install"
  },
  "dependencies": {
    "@fastify/env": "^4.2.0",
    "fastify": "^4.24.0",
    "fastify-plugin": "^4.5.1"
  },
  "devDependencies": {
    "@swc/helpers": "^0.5.3",
    "@types/node": "^20.8.5",
    "husky": "^8.0.3",
    "lint-staged": "^15.0.2",
    "regenerator-runtime": "^0.14.0",
    "ts-node": "~10.9.0",
    "tsx": "^4.19.1",
    "typescript": "^5.2.2"
  }
}
